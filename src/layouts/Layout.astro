---
interface Props {
  title: string;
}

import '../styles/global.css';

const { title } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="O'Shay Lighten — freelance creative, operated by Noira. Film, media, web development, automation." />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>
  <body class="bg-ink text-cream antialiased">
    <slot />
  </body>
</html>