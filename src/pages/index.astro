---
import Layout from '../layouts/Layout.astro';
---

<Layout title="O'Shay Lighten — Operated by Noira">
  <!-- HERO -->
  <section class="min-h-screen flex flex-col justify-center px-6 md:px-12 lg:px-24 pt-20">
    <div class="max-w-3xl">
      <p class="text-cream-dim text-xs tracking-[0.3em] uppercase mb-6 fade-up">O'SHAY LIGHTEN</p>
      <h1 class="text-4xl sm:text-5xl md:text-6xl lg:text-7xl font-serif leading-[0.95] mb-8 fade-up fade-up-d1">
        I run my business<br/>
        <span class="text-accent">through Noira.</span>
      </h1>
      <p class="text-cream-dim text-base md:text-lg leading-relaxed max-w-xl mb-10 fade-up fade-up-d2">
        Noira is my operator. She handles my briefings, runs my pipeline, manages my clients, and builds my tools — so I can focus on the work that pays.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 fade-up fade-up-d3">
        <a href="#briefings" class="inline-flex items-center justify-center border border-accent text-accent hover:bg-accent hover:text-ink px-6 py-3 text-sm tracking-wider transition-all">
          HOW IT WORKS
        </a>
        <a href="#work" class="inline-flex items-center justify-center border border-ink-border text-cream-dim hover:text-cream hover:border-cream-dim px-6 py-3 text-sm tracking-wider transition-all">
          SEE THE WORK
        </a>
      </div>
    </div>
    <div class="mt-16 text-cream-dim/40 text-xs tracking-widest fade-up fade-up-d4">
      <span class="cursor-blink">▌</span> NOIRA ONLINE
    </div>
  </section>

  <!-- RECURRING BRIEFINGS -->
  <section id="briefings" class="py-24 md:py-32 px-6 md:px-12 lg:px-24 border-t border-ink-border">
    <div class="max-w-4xl">
      <p class="text-accent text-xs tracking-[0.3em] uppercase mb-4">01</p>
      <h2 class="text-3xl md:text-4xl lg:text-5xl font-serif leading-tight mb-6">
        Recurring Briefings
      </h2>
      <p class="text-cream-dim text-base md:text-lg leading-relaxed max-w-2xl mb-12">
        Every morning (or whenever I need it), Noira gives me a sitrep — what's due, who owes me, what slipped, what's next. No digging through notes. No forgetting follow-ups.
      </p>
      <!-- Briefing cycle infographic -->
      <div class="mb-12 overflow-x-auto">
        <svg width="100%" viewBox="0 0 800 220" fill="none" xmlns="http://www.w3.org/2000/svg" class="min-w-[600px]">
          <!-- Center hub -->
          <circle cx="400" cy="110" r="60" stroke="#d4a853" stroke-width="2" fill="none"/>
          <circle cx="400" cy="110" r="44" stroke="#d4a853" stroke-width="1" fill="#d4a853" fill-opacity="0.08"/>
          <text x="400" y="105" text-anchor="middle" fill="#d4a853" font-size="11" font-family="monospace" letter-spacing="0.15em">NOIRA</text>
          <text x="400" y="122" text-anchor="middle" fill="#e8e0d0" font-size="9" font-family="monospace" letter-spacing="0.1em">BRIEFING</text>
          <!-- Pipeline node (top) -->
          <line x1="400" y1="50" x2="400" y2="22" stroke="#d4a853" stroke-width="1" stroke-dasharray="3 3"/>
          <circle cx="400" cy="14" r="10" stroke="#d4a853" stroke-width="1.5" fill="#d4a853" fill-opacity="0.15"/>
          <text x="400" y="0" text-anchor="middle" fill="#e8e0d0" font-size="8" font-family="monospace" letter-spacing="0.1em">PIPELINE</text>
          <!-- small list icon inside -->
          <line x1="396" y1="11" x2="404" y2="11" stroke="#d4a853" stroke-width="1" stroke-linecap="round"/>
          <line x1="396" y1="14" x2="404" y2="14" stroke="#d4a853" stroke-width="1" stroke-linecap="round"/>
          <line x1="396" y1="17" x2="402" y2="17" stroke="#d4a853" stroke-width="1" stroke-linecap="round"/>
          <!-- Follow-ups node (right) -->
          <line x1="460" y1="110" x2="510" y2="110" stroke="#d4a853" stroke-width="1" stroke-dasharray="3 3"/>
          <circle cx="524" cy="110" r="14" stroke="#d4a853" stroke-width="1.5" fill="#d4a853" fill-opacity="0.15"/>
          <text x="548" y="106" fill="#e8e0d0" font-size="8" font-family="monospace" letter-spacing="0.1em">FOLLOW-UPS</text>
          <text x="548" y="118" fill="#e8e0d0" font-size="7" font-family="sans-serif" opacity="0.5">text · call · email</text>
          <!-- person icon -->
          <circle cx="524" cy="105" r="4" stroke="#d4a853" stroke-width="1" fill="none"/>
          <path d="M518 119c0-4 2.7-6 6-6s6 2 6 6" stroke="#d4a853" stroke-width="1" fill="none" stroke-linecap="round"/>
          <!-- Calendar node (bottom) -->
          <line x1="400" y1="170" x2="400" y2="195" stroke="#d4a853" stroke-width="1" stroke-dasharray="3 3"/>
          <rect x="388" y="196" width="24" height="20" rx="2" stroke="#d4a853" stroke-width="1.5" fill="#d4a853" fill-opacity="0.15"/>
          <text x="400" y="226" text-anchor="middle" fill="#e8e0d0" font-size="8" font-family="monospace" letter-spacing="0.1em">CALENDAR</text>
          <text x="400" y="237" text-anchor="middle" fill="#e8e0d0" font-size="7" font-family="sans-serif" opacity="0.5">next 48h</text>
          <!-- calendar lines -->
          <line x1="388" y1="203" x2="412" y2="203" stroke="#d4a853" stroke-width="1"/>
          <line x1="393" y1="193" x2="393" y2="200" stroke="#d4a853" stroke-width="1" stroke-linecap="round"/>
          <line x1="407" y1="193" x2="407" y2="200" stroke="#d4a853" stroke-width="1" stroke-linecap="round"/>
          <rect x="391" y="207" width="4" height="3" fill="#d4a853" opacity="0.4"/>
          <rect x="397" y="207" width="4" height="3" fill="#d4a853" opacity="0.2"/>
          <rect x="403" y="207" width="4" height="3" fill="#d4a853" opacity="0.2"/>
          <!-- Wins & Flags node (left) -->
          <line x1="340" y1="110" x2="290" y2="110" stroke="#d4a853" stroke-width="1" stroke-dasharray="3 3"/>
          <circle cx="276" cy="110" r="14" stroke="#d4a853" stroke-width="1.5" fill="#d4a853" fill-opacity="0.15"/>
          <text x="252" y="106" text-anchor="end" fill="#e8e0d0" font-size="8" font-family="monospace" letter-spacing="0.1em">WINS & FLAGS</text>
          <text x="252" y="118" text-anchor="end" fill="#e8e0d0" font-size="7" font-family="sans-serif" opacity="0.5">money in · problems</text>
          <!-- flag icon -->
          <line x1="272" y1="103" x2="272" y2="118" stroke="#d4a853" stroke-width="1.2" stroke-linecap="round"/>
          <path d="M272 103h10c0 3-5 3-5 3s5 0 5 3h-10" stroke="#d4a853" stroke-width="1" fill="none" stroke-linejoin="round"/>
          <!-- Arrows showing flow: all feed into O'Shay -->
          <path d="M400 50 L580 40" stroke="#d4a853" stroke-width="0.5" stroke-dasharray="2 4" opacity="0.3"/>
          <path d="M460 110 L580 110" stroke="#d4a853" stroke-width="0.5" stroke-dasharray="2 4" opacity="0.3"/>
          <path d="M400 170 L580 180" stroke="#d4a853" stroke-width="0.5" stroke-dasharray="2 4" opacity="0.3"/>
          <path d="M276 110 L220 110" stroke="#d4a853" stroke-width="0.5" stroke-dasharray="2 4" opacity="0.3"/>
          <!-- O'SHAY output -->
          <rect x="580" y="72" width="100" height="76" rx="3" stroke="#d4a853" stroke-width="1.5" fill="none"/>
          <text x="630" y="102" text-anchor="middle" fill="#d4a853" font-size="10" font-family="monospace" letter-spacing="0.1em">O'SHAY</text>
          <text x="630" y="118" text-anchor="middle" fill="#e8e0d0" font-size="7" font-family="sans-serif" opacity="0.6">briefed & ready</text>
          <!-- arrows converging -->
          <path d="M580 50 l0 22" stroke="#d4a853" stroke-width="1" marker-end="url(#arrow)"/>
          <path d="M560 110 l20 0" stroke="#d4a853" stroke-width="1"/>
          <path d="M580 180 l0 -32" stroke="#d4a853" stroke-width="1"/>
        </svg>
      </div>
      <!-- Briefing cards below infographic -->
      <div class="grid grid-cols-1 md:grid-cols-2 gap-px bg-ink-border">
        <div class="bg-ink p-6 md:p-8">
          <p class="text-accent text-xs tracking-[0.2em] uppercase mb-2">Pipeline</p>
          <p class="text-cream text-sm leading-relaxed">Active projects, outstanding invoices, upcoming deadlines. Who's paid, who hasn't, what needs attention.</p>
        </div>
        <div class="bg-ink p-6 md:p-8">
          <p class="text-accent text-xs tracking-[0.2em] uppercase mb-2">Follow-ups</p>
          <p class="text-cream text-sm leading-relaxed">Who I need to text, call, or email. No lead goes cold. No client gets forgotten.</p>
        </div>
        <div class="bg-ink p-6 md:p-8">
          <p class="text-accent text-xs tracking-[0.2em] uppercase mb-2">Calendar</p>
          <p class="text-cream text-sm leading-relaxed">What's coming up in the next 48 hours. Meetings, deadlines, deliveries — all surfaced before I ask.</p>
        </div>
        <div class="bg-ink p-6 md:p-8">
          <p class="text-accent text-xs tracking-[0.2em] uppercase mb-2">Wins & Flags</p>
          <p class="text-cream text-sm leading-relaxed">Money in, projects completed, problems that need my eyes. The stuff that can't wait.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- NANO BANANA PIPELINE -->
  <section id="pipeline" class="py-24 md:py-32 px-6 md:px-12 lg:px-24 border-t border-ink-border">
    <div class="max-w-4xl">
      <p class="text-accent text-xs tracking-[0.3em] uppercase mb-4">02</p>
      <h2 class="text-3xl md:text-4xl lg:text-5xl font-serif leading-tight mb-6">
        Nano Banana Pipeline
      </h2>
      <p class="text-cream-dim text-base md:text-lg leading-relaxed max-w-2xl mb-12">
        Clients send iPhone photos. I give Noira the guardrails — style, tone, output specs. She runs the pipeline in the background, generating enhanced variations and dumping finished files into a dedicated folder. I review, I deliver. No manual editing marathon.
      </p>
      <!-- Pipeline flow SVG -->
      <div class="mb-10 overflow-x-auto">
        <svg width="100%" viewBox="0 0 600 100" fill="none" xmlns="http://www.w3.org/2000/svg" class="min-w-[500px]">
          <rect x="10" y="25" width="110" height="50" rx="2" stroke="#d4a853" stroke-width="1.5" fill="none"/>
          <text x="65" y="45" text-anchor="middle" fill="#d4a853" font-size="9" font-family="monospace" letter-spacing="0.1em">01</text>
          <text x="65" y="62" text-anchor="middle" fill="#e8e0d0" font-size="10" font-family="sans-serif">Photos In</text>
          <line x1="120" y1="50" x2="165" y2="50" stroke="#d4a853" stroke-width="1" stroke-dasharray="4 3"/>
          <rect x="165" y="25" width="110" height="50" rx="2" stroke="#d4a853" stroke-width="1.5" fill="none"/>
          <text x="220" y="45" text-anchor="middle" fill="#d4a853" font-size="9" font-family="monospace" letter-spacing="0.1em">02</text>
          <text x="220" y="62" text-anchor="middle" fill="#e8e0d0" font-size="10" font-family="sans-serif">Guardrails</text>
          <line x1="275" y1="50" x2="320" y2="50" stroke="#d4a853" stroke-width="1" stroke-dasharray="4 3"/>
          <rect x="320" y="25" width="110" height="50" rx="2" stroke="#d4a853" stroke-width="1.5" fill="none"/>
          <text x="375" y="45" text-anchor="middle" fill="#d4a853" font-size="9" font-family="monospace" letter-spacing="0.1em">03</text>
          <text x="375" y="62" text-anchor="middle" fill="#e8e0d0" font-size="10" font-family="sans-serif">Noira Runs</text>
          <line x1="430" y1="50" x2="475" y2="50" stroke="#d4a853" stroke-width="1" stroke-dasharray="4 3"/>
          <rect x="475" y="25" width="110" height="50" rx="2" stroke="#d4a853" stroke-width="1.5" fill="none"/>
          <text x="530" y="45" text-anchor="middle" fill="#d4a853" font-size="9" font-family="monospace" letter-spacing="0.1em">04</text>
          <text x="530" y="62" text-anchor="middle" fill="#e8e0d0" font-size="10" font-family="sans-serif">Review</text>
        </svg>
      </div>
      <div class="flex flex-col gap-6 max-w-2xl">
        <div class="flex items-start gap-4">
          <span class="text-accent font-mono text-sm mt-1 shrink-0">01</span>
          <div>
            <p class="text-cream text-sm font-semibold mb-1">Client sends photos</p>
            <p class="text-cream-dim text-sm leading-relaxed">iPhone shots, raw files, whatever they've got. Dropped in a shared folder or sent straight over.</p>
          </div>
        </div>
        <div class="flex items-start gap-4">
          <span class="text-accent font-mono text-sm mt-1 shrink-0">02</span>
          <div>
            <p class="text-cream text-sm font-semibold mb-1">I set the guardrails</p>
            <p class="text-cream-dim text-sm leading-relaxed">Style direction, color grading, crop ratios, output specs. I tell Noira what the final product should look like.</p>
          </div>
        </div>
        <div class="flex items-start gap-4">
          <span class="text-accent font-mono text-sm mt-1 shrink-0">03</span>
          <div>
            <p class="text-cream text-sm font-semibold mb-1">Noira runs the pipeline</p>
            <p class="text-cream-dim text-sm leading-relaxed">Background processing. Enhanced variations, consistent style, multiple formats. All output to a dedicated folder — no manual editing.</p>
          </div>
        </div>
        <div class="flex items-start gap-4">
          <span class="text-accent font-mono text-sm mt-1 shrink-0">04</span>
          <div>
            <p class="text-cream text-sm font-semibold mb-1">I review and deliver</p>
            <p class="text-cream-dim text-sm leading-relaxed">Quick pass on the output, pick the winners, deliver to client. Hours of editing compressed to minutes of review.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CUSTOM CRM -->
  <section id="crm" class="py-24 md:py-32 px-6 md:px-12 lg:px-24 border-t border-ink-border">
    <div class="max-w-4xl">
      <p class="text-accent text-xs tracking-[0.3em] uppercase mb-4">03</p>
      <h2 class="text-3xl md:text-4xl lg:text-5xl font-serif leading-tight mb-6">
        Custom CRM
      </h2>
      <p class="text-cream-dim text-base md:text-lg leading-relaxed max-w-2xl mb-12">
        Built in Obsidian. Tracked by Noira. Every client, project, invoice, and communication — one vault, zero subscription fees, fully mine.
      </p>
      <!-- CRM infographic -->
      <div class="mb-12 overflow-x-auto">
        <svg width="100%" viewBox="0 0 800 140" fill="none" xmlns="http://www.w3.org/2000/svg" class="min-w-[600px]">
          <!-- Vault hub -->
          <rect x="340" y="30" width="120" height="80" rx="3" stroke="#d4a853" stroke-width="2" fill="#d4a853" fill-opacity="0.06"/>
          <text x="400" y="60" text-anchor="middle" fill="#d4a853" font-size="10" font-family="monospace" letter-spacing="0.15em">OBSIDIAN</text>
          <text x="400" y="75" text-anchor="middle" fill="#d4a853" font-size="10" font-family="monospace" letter-spacing="0.15em">VAULT</text>
          <text x="400" y="95" text-anchor="middle" fill="#e8e0d0" font-size="7" font-family="sans-serif" opacity="0.5">$0/mo · no subscriptions</text>
          <!-- Client nodes feeding in -->
          <circle cx="140" cy="50" r="20" stroke="#d4a853" stroke-width="1.5" fill="#d4a853" fill-opacity="0.1"/>
          <text x="140" y="48" text-anchor="middle" fill="#e8e0d0" font-size="8" font-family="sans-serif">Clients</text>
          <text x="140" y="58" text-anchor="middle" fill="#d4a853" font-size="9" font-family="monospace">5</text>
          <line x1="160" y1="50" x2="340" y2="55" stroke="#d4a853" stroke-width="1" stroke-dasharray="3 3"/>
          <circle cx="140" cy="110" r="20" stroke="#d4a853" stroke-width="1.5" fill="#d4a853" fill-opacity="0.1"/>
          <text x="140" y="108" text-anchor="middle" fill="#e8e0d0" font-size="8" font-family="sans-serif">Revenue</text>
          <text x="140" y="118" text-anchor="middle" fill="#d4a853" font-size="9" font-family="monospace">$23K+</text>
          <line x1="160" y1="110" x2="340" y2="85" stroke="#d4a853" stroke-width="1" stroke-dasharray="3 3"/>
          <!-- Output nodes -->
          <circle cx="660" cy="50" r="20" stroke="#d4a853" stroke-width="1.5" fill="#d4a853" fill-opacity="0.1"/>
          <text x="660" y="48" text-anchor="middle" fill="#e8e0d0" font-size="7" font-family="sans-serif">Follow-ups</text>
          <text x="660" y="58" text-anchor="middle" fill="#d4a853" font-size="9" font-family="monospace">0 missed</text>
          <line x1="460" y1="55" x2="640" y2="50" stroke="#d4a853" stroke-width="1" stroke-dasharray="3 3"/>
          <circle cx="660" cy="110" r="20" stroke="#d4a853" stroke-width="1.5" fill="#d4a853" fill-opacity="0.1"/>
          <text x="660" y="108" text-anchor="middle" fill="#e8e0d0" font-size="7" font-family="sans-serif">Invoices</text>
          <text x="660" y="118" text-anchor="middle" fill="#e8e0d0" font-size="7" font-family="sans-serif" opacity="0.5">tracked</text>
          <line x1="460" y1="85" x2="640" y2="110" stroke="#d4a853" stroke-width="1" stroke-dasharray="3 3"/>
        </svg>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-px bg-ink-border">
        <div class="bg-ink p-6 md:p-8">
          <p class="text-accent text-2xl font-serif mb-2">5</p>
          <p class="text-cream text-sm font-semibold mb-1">Active Clients</p>
          <p class="text-cream-dim text-xs leading-relaxed">Each with a full profile — contact info, project history, payment status, communication log.</p>
        </div>
        <div class="bg-ink p-6 md:p-8">
          <p class="text-accent text-2xl font-serif mb-2">$23,000+</p>
          <p class="text-cream text-sm font-semibold mb-1">Revenue Tracked</p>
          <p class="text-cream-dim text-xs leading-relaxed">Every invoice, every payment method, every outstanding balance. In one place.</p>
        </div>
        <div class="bg-ink p-6 md:p-8">
          <p class="text-accent text-2xl font-serif mb-2">0</p>
          <p class="text-cream text-sm font-semibold mb-1">Missed Follow-ups</p>
          <p class="text-cream-dim text-xs leading-relaxed">Noira tracks when to follow up, how to reach them, and what to say. Nothing falls through.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- WEB DEVELOPMENT -->
  <section id="work" class="py-24 md:py-32 px-6 md:px-12 lg:px-24 border-t border-ink-border">
    <div class="max-w-4xl">
      <p class="text-accent text-xs tracking-[0.3em] uppercase mb-4">04</p>
      <h2 class="text-3xl md:text-4xl lg:text-5xl font-serif leading-tight mb-6">
        Web Development
      </h2>
      <p class="text-cream-dim text-base md:text-lg leading-relaxed max-w-2xl mb-12">
        Design to deployment. Forms that feed into the pipeline. Sites built around how I actually work — not the other way around.
      </p>
      <div class="flex flex-col gap-8">
        <!-- Win: 386 blogs -->
        <div class="border border-ink-border p-6 md:p-8 hover:border-accent/30 transition-colors">
          <div class="flex items-center gap-3 mb-3">
            <span class="text-accent text-xs tracking-[0.2em] uppercase">Win</span>
            <span class="text-cream-dim/30 text-xs">—</span>
            <span class="text-cream-dim text-xs">Wilbers Law Firm</span>
          </div>
          <p class="text-cream text-lg font-serif mb-2">386 blog posts scraped in one pass</p>
          <p class="text-cream-dim text-sm leading-relaxed">Zero failures. 9.2MB of content, structured and filed. The client's entire content library — captured, organized, ready for their new site.</p>
        </div>
        <!-- Win: Home & Soil -->
        <div class="border border-ink-border p-6 md:p-8 hover:border-accent/30 transition-colors">
          <div class="flex items-center gap-3 mb-3">
            <span class="text-accent text-xs tracking-[0.2em] uppercase">Win</span>
            <span class="text-cream-dim/30 text-xs">—</span>
            <span class="text-cream-dim text-xs">Home & Soil</span>
          </div>
          <p class="text-cream text-lg font-serif mb-2">5-step lead form → pipeline integration</p>
          <p class="text-cream-dim text-sm leading-relaxed">Multi-step form captures project type, property info, contact, address (broken out for Jobber), and details. Submissions go straight to Formspree → Discord. Lead comes in, I get notified, Noira logs it. Zero manual entry.</p>
        </div>

        <!-- Services list -->
        <div class="mt-4">
          <p class="text-cream-dim text-xs tracking-[0.2em] uppercase mb-4">What I build</p>
          <div class="grid grid-cols-2 md:grid-cols-3 gap-x-8 gap-y-2">
            <p class="text-cream/70 text-sm">Landing pages</p>
            <p class="text-cream/70 text-sm">Multi-page sites</p>
            <p class="text-cream/70 text-sm">Lead forms</p>
            <p class="text-cream/70 text-sm">Pipeline integration</p>
            <p class="text-cream/70 text-sm">CRM setup</p>
            <p class="text-cream/70 text-sm">Automation</p>
            <p class="text-cream/70 text-sm">Content scraping</p>
            <p class="text-cream/70 text-sm">Receipt & invoicing</p>
            <p class="text-cream/70 text-sm">Ongoing ops</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ABOUT -->
  <section id="about" class="py-24 md:py-32 px-6 md:px-12 lg:px-24 border-t border-ink-border">
    <div class="max-w-4xl">
      <p class="text-accent text-xs tracking-[0.3em] uppercase mb-4">ABOUT</p>
      <h2 class="text-3xl md:text-4xl lg:text-5xl font-serif leading-tight mb-8">
        O'Shay Lighten
      </h2>
      <div class="max-w-2xl space-y-5">
        <p class="text-cream-dim text-base leading-relaxed">
          Freelance creative in Bolivar, Missouri. I do film, media, front-end development, websites, videos, ad management — the full stack of creative services for businesses that need someone who actually shows up.
        </p>
        <p class="text-cream-dim text-base leading-relaxed">
          Noira runs the operations side so I can stay in the creative. She briefs me, tracks my pipeline, manages my clients, and builds my tools. I make the calls. She makes sure nothing gets missed.
        </p>
      </div>
    </div>
  </section>

  <!-- CONTACT -->
